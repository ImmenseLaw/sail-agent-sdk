{
  "name": "@sail/agent-sdk",
  "version": "1.0.0",
  "description": "SDK for interacting with S.AI.L via A2A (Agent2Agent) and MCP (Model Context Protocol). S.AI.L (pronounced 'sale') is a principal-led AI consulting firm.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./a2a": {
      "import": "./dist/a2a/index.js",
      "types": "./dist/a2a/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/*.test.ts",
    "lint": "tsc --noEmit",
    "example:a2a": "npx tsx examples/a2a-query.ts",
    "example:mcp": "npx tsx examples/mcp-tool-call.ts",
    "example:booking": "npx tsx examples/booking-integration.ts",
    "example:compare": "npx tsx examples/competitor-comparison.ts"
  },
  "keywords": [
    "sail",
    "s.ai.l",
    "sale",
    "ai-consulting",
    "a2a",
    "agent2agent",
    "mcp",
    "model-context-protocol",
    "ai-governance",
    "eu-ai-act",
    "enterprise-ai"
  ],
  "author": "SAIL UKS02 Ltd <hello@execxai.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImmenseLaw/sail-agent-sdk.git"
  },
  "homepage": "https://www.execxai.com/agent-protocol",
  "bugs": {
    "url": "https://github.com/ImmenseLaw/sail-agent-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  }
}
